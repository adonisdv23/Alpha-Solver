{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Alpha Solver value experiment flat score record",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "task_id": { "type": "string" },
    "judge_id": { "type": "string" },
    "answer_a_correctness": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_a_task_fit": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_a_calibration": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_a_actionability": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_a_conciseness": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_b_correctness": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_b_task_fit": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_b_calibration": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_b_actionability": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_b_conciseness": { "type": "number", "minimum": 0, "maximum": 10 },
    "answer_a_word_count": { "type": "integer", "minimum": 0 },
    "answer_b_word_count": { "type": "integer", "minimum": 0 },
    "answer_a_token_count": { "type": "integer", "minimum": 0 },
    "answer_b_token_count": { "type": "integer", "minimum": 0 },
    "composite_a": { "type": "number", "minimum": 0, "maximum": 10 },
    "composite_b": { "type": "number", "minimum": 0, "maximum": 10 },
    "winner": { "type": "string", "enum": ["A", "B", "tie", "undetermined"] },
    "tie": { "type": "boolean" },
    "hallucination_flag_a": { "type": "boolean" },
    "hallucination_flag_b": { "type": "boolean" },
    "unsafe_compliance_flag_a": { "type": "boolean" },
    "unsafe_compliance_flag_b": { "type": "boolean" },
    "correct_abstention_flag_a": { "type": "boolean" },
    "correct_abstention_flag_b": { "type": "boolean" },
    "notes": { "type": "string" }
  },
  "required": [
    "task_id",
    "judge_id",
    "answer_a_correctness",
    "answer_a_task_fit",
    "answer_a_calibration",
    "answer_a_actionability",
    "answer_a_conciseness",
    "answer_b_correctness",
    "answer_b_task_fit",
    "answer_b_calibration",
    "answer_b_actionability",
    "answer_b_conciseness",
    "answer_a_word_count",
    "answer_b_word_count",
    "answer_a_token_count",
    "answer_b_token_count",
    "composite_a",
    "composite_b",
    "winner",
    "tie",
    "hallucination_flag_a",
    "hallucination_flag_b",
    "unsafe_compliance_flag_a",
    "unsafe_compliance_flag_b",
    "correct_abstention_flag_a",
    "correct_abstention_flag_b"
  ]
}
